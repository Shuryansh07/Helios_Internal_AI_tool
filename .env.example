# Copy this file to ".env" and fill in the keys you have.
# You only NEED the key for the provider(s) you actually use.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Meeting Intelligence dashboard model (transcripts are large — gpt-4o-mini has a
# higher tokens-per-minute limit and is cheaper). TRANSCRIPT_CHAR_LIMIT caps tokens/request.
OPENAI_DASHBOARD_MODEL=gpt-4o-mini
TRANSCRIPT_CHAR_LIMIT=40000
# Proposal generator input caps (keep a big requirement + reference proposals under the TPM limit).
PROPOSAL_REQUIREMENT_CHAR_LIMIT=24000
PROPOSAL_REFERENCES_CHAR_LIMIT=16000

# Optional - add later when you have them
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Live Capture transcription (speech-to-text) ----
# Hugging Face free Inference API by default (token from huggingface.co/settings/tokens).
# Falls back to OpenAI Whisper (OPENAI_API_KEY) if no HF token is set.
TRANSCRIBE_PROVIDER=huggingface
HF_API_TOKEN=
HF_ASR_MODEL=openai/whisper-large-v3
OPENAI_ASR_MODEL=whisper-1

# Company details that appear on every proposal (edit freely)
COMPANY_NAME=Helios tech labs
COMPANY_TAGLINE=
COMPANY_EMAIL=gk.dialabank@gmail.com
COMPANY_PHONE=
COMPANY_WEBSITE=

# ---- Zoho WorkDrive (optional: auto-fetch past proposals from a folder) ----
# Fill these to enable WorkDrive search; leave blank to keep using manual upload.
ZOHO_DC=com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_WORKDRIVE_FOLDER_ID=

# ---- Zoho Meetings (optional: Meeting Intelligence dashboard) ----
# DISABLED by default — the dashboard works via manual transcript paste/upload.
# To enable live meeting pulls you must (1) re-authorise ZOHO_REFRESH_TOKEN with
# ZohoMeeting.meeting.READ + ZohoMeeting.recording.READ scopes, (2) set your org id
# in ZOHO_MEETINGS_ZSOID, then (3) set ZOHO_MEETINGS_ENABLED=true.
ZOHO_MEETINGS_ENABLED=false
ZOHO_MEETINGS_ZSOID=
ZOHO_MEETINGS_BASE_URL=

# WorkDrive folder of example flowchart images — the Process Architect trains on
# these to match your house flowchart style.
ZOHO_FLOWCHART_FOLDER_ID=
# Zoho Projects portal id for the Insights page (optional — auto-detected from the
# first portal if left blank).
ZOHO_PROJECTS_PORTAL=
# Image model for the flowchart "AI Image" render mode.
OPENAI_IMAGE_MODEL=gpt-image-2

# ---- Authentication ----
# Random string used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# The first user — created automatically on first run if no users exist yet.
# After you log in once, change the password via "Forgot password" if desired.
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=

# ---- SMTP (used to send password-reset OTPs) ----
# For Gmail: SMTP_USER is your full Gmail address, SMTP_APP_PASSWORD is a
# 16-character app password from https://myaccount.google.com/apppasswords.
# Leave SMTP_USER + SMTP_APP_PASSWORD empty for dev mode (OTP prints to console).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=
